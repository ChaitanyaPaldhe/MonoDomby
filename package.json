{
  "name": "monopoly",
  "version": "1.0.0",
  "private": true,
  "description": "Production-grade browser-based Monopoly engine",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm -r test",
    "test:unit": "pnpm -r test:unit",
    "test:integration": "pnpm -r test:integration",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.62.0",
    "vitest": "^2.0.0"
  }
}
